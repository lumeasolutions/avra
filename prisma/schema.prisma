generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspacePlan {
  STARTER
  PRO
  ENTERPRISE
}

enum TradeType {
  ARCHITECTE_INTERIEUR
  CUISINISTE
  MENUISIER
  AGENCEUR
  DECORATEUR
  PROMOTEUR
  AUTRE
}

enum ClientType {
  PARTICULIER
  PROFESSIONNEL
}

enum AddressType {
  BILLING
  SITE
  OTHER
}

enum ProjectLifecycleStatus {
  DRAFT
  VENTE
  SIGNE
  EN_CHANTIER
  RECEPTION
  SAV
  CLOTURE
  PERDU
  ARCHIVE
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PipelineStatus {
  LEAD
  PROSPECT
  DEVIS_ENVOYE
  NEGOCIATION
  GAGNE
  PERDU
}

enum EventCalendarType {
  PERSONAL
  GESTION
}

enum EventType {
  REUNION
  VISITE_CHANTIER
  LIVRAISON
  INSTALLATION
  RDV_CLIENT
  RELANCE
  FORMATION
  DEPLACEMENT
  APPEL
  AUTRE
}

enum IntervenantType {
  POSEUR
  ELECTRICIEN
  MACON
  PEINTRE
  PLOMBIER
  CARRELEUR
  MENUISIER
  CHAUFFAGISTE
  SERRURIER
  GEOMETRE
  AUTRE
}

enum IntervenantRequestStatus {
  PENDING
  SENT
  ACCEPTED
  REFUSED
  CANCELLED
}

/// Types de demande envoyees aux intervenants depuis l'app pro.
/// Centralise tous les workflows : pose, livraison, SAV, mesure, etc.
enum DemandeType {
  POSE
  LIVRAISON
  SAV
  MESURE
  DEVIS
  CONFIRMATION_COMMANDE
  COMPLEMENT
  AUTRE
}

/// Workflow d'une demande adressee a un intervenant.
enum DemandeStatus {
  ENVOYEE      // Cree, intervenant pas encore connecte
  VUE          // Intervenant a ouvert la demande
  ACCEPTEE     // Intervenant a accepte de la prendre
  REFUSEE      // Intervenant a decline
  EN_COURS     // Intervention en cours
  TERMINEE     // Intervention finie (avec eventuels docs en retour)
  ANNULEE      // Le pro a annule la demande
}

/// Statut d'une invitation envoyee a un intervenant pour creer/lier
/// son compte au portail.
enum IntervenantInvitationStatus {
  PENDING       // Token actif, intervenant pas encore clique
  ACCEPTED      // Compte cree ou relation creee
  REFUSED       // Intervenant a decline
  EXPIRED       // Token > expiresAt
  REVOKED       // Pro a revoque le lien avant action
}

enum DocumentKind {
  PLAN
  DEVIS
  FACTURE
  CONTRAT
  BON_COMMANDE
  PHOTO
  IA_RENDER
  AUTRE
}

enum FileMimeCategory {
  IMAGE
  PDF
  DOCUMENT
  VIDEO
  ARCHIVE
  OTHER
}

enum StockItemStatus {
  AVAILABLE
  RESERVED
  OUT_OF_STOCK
  DISCONTINUED
  ORDERED
}

enum StockCategory {
  MEUBLE
  ELECTROMENAGER
  LUMINAIRE
  ACCESSOIRE
  MATERIAU
  TEXTILE
  SANITAIRE
  AUTRE
}

enum IaJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum IaJobType {
  PHOTOREALISM_ENHANCE
  COLOR_VARIATION
  EDIT
  PLAN_COMPARISON
  TEXT_ASSISTANT
}

enum PaymentType {
  ACOMPTE
  SOLDE
  FACTURE
  AVOIR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum SignatureStatus {
  PENDING
  SENT
  SIGNED
  REFUSED
  EXPIRED
  CANCELLED
}

enum NotificationScope {
  SYSTEM
  PROJECT
  CLIENT
  PAYMENT
  SIGNATURE
  IA
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  EXPORT
  UPLOAD
  SIGN
  PAY
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKSPACE & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  plan        WorkspacePlan @default(STARTER)
  trialEndsAt DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userWorkspaces     UserWorkspace[]
  settings           WorkspaceSettings?
  clients            Client[]
  projects           Project[]
  intervenants       Intervenant[]
  documents          Document[]
  storedFiles        StoredFile[]
  events             Event[]
  stockItems         StockItem[]
  suppliers          Supplier[]
  supplierOrders     SupplierOrder[]
  paymentRequests    PaymentRequest[]
  signatureRequests  SignatureRequest[]
  iaJobs             IaJob[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  automationRules    AutomationRule[]
  quotes             Quote[]
  dossierDocuments   DossierDocument[]
  documentAuditLogs  DocumentAuditLog[]
  intervenantInvitations IntervenantInvitation[]
  demandes           Demande[]
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  passwordHash            String
  firstName               String
  lastName                String
  avatarUrl               String?
  isActive                Boolean   @default(true)
  lastLoginAt             DateTime?
  refreshToken            String?   // ✅ Hashed refresh token
  refreshTokenExpiresAt   DateTime? // ✅ Refresh token expiry
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  userWorkspaces    UserWorkspace[]
  uploadedFiles     StoredFile[]
  createdDocuments  Document[]
  createdAuditLogs  AuditLog[]
  notifications     Notification[]
  iaJobs            IaJob[]
  createdEvents     Event[]
  ownedProjects     Project[]       @relation("ProjectOwner")
  createdDossierDocuments DossierDocument[] @relation("DossierDocumentCreatedBy")
  documentAuditLogs DocumentAuditLog[]
  /// Profil intervenant (1-1 si l'utilisateur est un intervenant connecte).
  intervenantProfiles      Intervenant[]            @relation("IntervenantUser")
  intervenantInvitationsCreated  IntervenantInvitation[] @relation("IntervenantInvitationCreatedBy")
  intervenantInvitationsAccepted IntervenantInvitation[] @relation("IntervenantInvitationAcceptedBy")
  demandesCreated          Demande[]                @relation("DemandeCreatedBy")
  demandeMessages          DemandeMessage[]         @relation("DemandeMessageAuthor")
  demandeAttachments       DemandeAttachment[]      @relation("DemandeAttachmentUploadedBy")
  demandeStatusEvents      DemandeStatusEvent[]     @relation("DemandeStatusEventTriggeredBy")
}

model UserWorkspace {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole  @default(MEMBER)
  joinedAt    DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model WorkspaceSettings {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  vatRate           Decimal   @default(20) @db.Decimal(5, 2)
  currency          String    @default("EUR")
  marginThreshold   Decimal?  @db.Decimal(5, 2)
  enableIa          Boolean   @default(true)
  enableSignature   Boolean   @default(false)
  enablePayment     Boolean   @default(false)
  logoUrl           String?
  address           String?
  siret             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id          String     @id @default(cuid())
  workspaceId String
  type        ClientType @default(PARTICULIER)
  companyName String?
  firstName   String?
  lastName    String?
  email       String?
  phone       String?
  vatNumber   String?
  notes       String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  addresses   Address[]
  contacts    Contact[]
  projects    Project[]

  @@index([workspaceId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Address {
  id          String      @id @default(cuid())
  clientId    String
  type        AddressType @default(SITE)
  line1       String
  line2       String?
  city        String
  postalCode  String
  country     String      @default("FR")
  createdAt   DateTime    @default(now())

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id              String                 @id @default(cuid())
  workspaceId     String
  clientId        String
  ownerId         String?
  name            String
  reference       String?
  tradeType       TradeType              @default(AUTRE)
  lifecycleStatus ProjectLifecycleStatus @default(DRAFT)
  pipelineStatus  PipelineStatus         @default(LEAD)
  priority        ProjectPriority        @default(MEDIUM)
  description     String?
  saleAmount      Decimal?               @db.Decimal(12, 2)
  purchaseAmount  Decimal?               @db.Decimal(12, 2)
  saleSignedAt    DateTime?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  workspace            Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client               Client                 @relation(fields: [clientId], references: [id], onDelete: Restrict)
  owner                User?                  @relation("ProjectOwner", fields: [ownerId], references: [id])
  folders              ProjectFolder[]
  documents            Document[]
  events               Event[]
  projectIntervenants  ProjectIntervenant[]
  projectStockItems    ProjectStockItem[]
  stageData            ProjectStageData[]
  customFieldValues    ProjectCustomFieldValue[]
  supplierOrders       SupplierOrder[]
  paymentRequests      PaymentRequest[]
  signatureRequests    SignatureRequest[]
  iaJobs               IaJob[]
  auditLogs            AuditLog[]
  quotes               Quote[]
  reminders            Reminder[]
  dossierDocuments     DossierDocument[]
  demandes             Demande[]               @relation("DemandeProject")

  @@index([workspaceId])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DOSSIER DOCUMENTS (sous-dossiers frontend : DOSSIER RENSEIGNEMENT, RELEVE, etc.)
// Stockage : Supabase Storage (bucket privé), accès uniquement via URL signée
// générée par l'API après validation d'ownership workspace.
// ─────────────────────────────────────────────────────────────────────────────

model DossierDocument {
  id              String   @id @default(cuid())
  workspaceId     String
  projectId       String
  subfolderLabel  String
  storageBucket   String
  storagePath     String   @unique
  originalName    String
  mimeType        String?
  sizeBytes       Int?
  createdById     String
  createdAt       DateTime @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("DossierDocumentCreatedBy", fields: [createdById], references: [id])
  demandeAttachments DemandeAttachment[]

  @@index([projectId])
  @@index([workspaceId, projectId, subfolderLabel])
}

model ProjectFolder {
  id              String         @id @default(cuid())
  projectId       String
  parentFolderId  String?
  name            String
  position        Int            @default(0)
  createdAt       DateTime       @default(now())

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          ProjectFolder? @relation("FolderTree", fields: [parentFolderId], references: [id])
  children        ProjectFolder[] @relation("FolderTree")
  documents       Document[]

  @@index([projectId])
}

model ProjectStageData {
  id          String   @id @default(cuid())
  projectId   String
  stage       String
  data        Json
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stage])
}

model ProjectCustomFieldValue {
  id          String   @id @default(cuid())
  projectId   String
  fieldName   String
  fieldType   String
  value       String?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectIntervenant {
  projectId       String
  intervenantId   String
  assignedAt      DateTime @default(now())

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  intervenant     Intervenant  @relation(fields: [intervenantId], references: [id], onDelete: Cascade)

  @@id([projectId, intervenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DOCUMENTS & FILES
// ─────────────────────────────────────────────────────────────────────────────

model StoredFile {
  id            String          @id @default(cuid())
  workspaceId   String
  uploadedById  String
  storageKey    String          @unique
  originalName  String
  mimeType      String
  mimeCategory  FileMimeCategory @default(OTHER)
  extension     String
  sizeBytes     Int
  checksum      String?
  publicUrl     String?
  createdAt     DateTime        @default(now())

  workspace         Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy        User        @relation(fields: [uploadedById], references: [id])
  documents         Document[]

  @@index([workspaceId])
}

model Document {
  id              String       @id @default(cuid())
  workspaceId     String
  projectId       String?
  storedFileId    String
  createdById     String
  folderId        String?
  title           String
  kind            DocumentKind @default(AUTRE)
  visibilityClient Boolean     @default(false)
  version         Int          @default(1)
  /// Date d'expiration optionnelle (Kbis ~3 mois, attestation assurance ~1 an).
  /// Null = pas de péremption. Une alerte UI apparait à J-30.
  expiresAt       DateTime?
  /// Description / notes libres saisies par l'admin (mémo interne).
  description     String?      @db.Text
  /// Tags personnalisés en CSV : ex "urgent,2026,fournisseur-blum".
  /// Format simple pour éviter une table dédiée — on filtre côté UI.
  tagsCsv         String?
  /// Document parent si cette ligne est une nouvelle version d'un autre.
  /// Permet le versioning : on garde toutes les versions et on remonte
  /// la chaîne via parentDocumentId.
  parentDocumentId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  storedFile        StoredFile     @relation(fields: [storedFileId], references: [id])
  createdBy         User           @relation(fields: [createdById], references: [id])
  folder            ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  parentDocument    Document?      @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childVersions     Document[]     @relation("DocumentVersions")
  shares            DocumentShare[]
  auditLogs         DocumentAuditLog[]
  iaJobsAsSource    IaJob[]        @relation("IaSourceDoc")
  iaJobsAsResult    IaJob[]        @relation("IaResultDoc")
  demandeAttachments DemandeAttachment[] @relation("DemandeAttachmentDoc")

  @@index([workspaceId])
  @@index([projectId])
  @@index([workspaceId, projectId, expiresAt])
  @@index([parentDocumentId])
}

/// Audit log des actions effectuées sur les documents (admin docs notamment).
/// Conservation 90 jours par défaut (RGPD), pruning via cron côté backend.
///
/// `action` est un string libre pour rester extensible :
///   'upload', 'download', 'delete', 'replace', 'share-create',
///   'share-revoke', 'tags-update', 'expiration-update',
///   'category-update', 'rename'.
model DocumentAuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  documentId  String?
  /// Conservé même si le document est supprimé — trace permanente.
  documentTitle String
  userId      String
  userEmail   String
  action      String
  /// Métadonnées libres (JSON string) : ip, userAgent, anciennes valeurs…
  meta        String?  @db.Text
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  user        User      @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([documentId])
  @@index([userId])
}

model DocumentShare {
  id          String    @id @default(cuid())
  documentId  String
  token       String    @unique @default(cuid())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANNING & EVENTS
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id              String            @id @default(cuid())
  workspaceId     String
  projectId       String?
  createdById     String
  calendarType    EventCalendarType @default(GESTION)
  type            EventType         @default(AUTRE)
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime?
  allDay          Boolean           @default(false)
  location        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy           User               @relation(fields: [createdById], references: [id])
  eventIntervenants   EventIntervenant[]
  reminders           Reminder[]
  demandes            Demande[]          @relation("DemandeEvent")

  @@index([workspaceId])
}

model EventIntervenant {
  eventId         String
  intervenantId   String

  event           Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  intervenant     Intervenant  @relation(fields: [intervenantId], references: [id], onDelete: Cascade)

  @@id([eventId, intervenantId])
}

model Reminder {
  id          String    @id @default(cuid())
  projectId   String?
  folderId    String?
  eventId     String?
  message     String
  remindAt    DateTime
  isDone      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INTERVENANTS
// ─────────────────────────────────────────────────────────────────────────────

model Intervenant {
  id              String          @id @default(cuid())
  workspaceId     String
  type            IntervenantType @default(AUTRE)
  companyName     String?
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  notes           String?
  portalEnabled   Boolean         @default(false)
  portalToken     String?         @unique
  /// Lien vers le compte User si l'intervenant a accepte une invitation
  /// au portail (NULL = annuaire seul, sans compte connecte).
  userId          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                User?                @relation("IntervenantUser", fields: [userId], references: [id], onDelete: SetNull)
  projects            ProjectIntervenant[]
  eventIntervenants   EventIntervenant[]
  requests            IntervenantRequest[]
  invitations         IntervenantInvitation[]
  demandes            Demande[]

  @@index([workspaceId])
  @@index([userId])
}

/// Invitation envoyee a un intervenant pour creer (ou lier) son compte
/// au portail. Token sécurisé 192 bits, expiration 14 jours par défaut.
/// Une invitation peut etre acceptee, refusee, expirer, ou etre revoquee.
model IntervenantInvitation {
  id              String                       @id @default(cuid())
  intervenantId   String
  workspaceId     String
  /// Token URL-safe (256 bits hex). Le pro envoie le lien
  /// /intervenant/invitation/{token} a l'intervenant.
  token           String                       @unique
  /// Email cible (pre-rempli sur la page d'inscription).
  email           String
  status          IntervenantInvitationStatus  @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  refusedAt       DateTime?
  revokedAt       DateTime?
  /// Si le compte User est cree au moment de l'acceptation, on stocke l'ID.
  acceptedByUserId String?
  /// Message libre du pro envoye dans l'email d'invitation.
  message         String?
  createdById     String
  createdAt       DateTime                     @default(now())

  intervenant     Intervenant @relation(fields: [intervenantId], references: [id], onDelete: Cascade)
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User        @relation("IntervenantInvitationCreatedBy", fields: [createdById], references: [id])
  acceptedByUser  User?       @relation("IntervenantInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([intervenantId])
  @@index([email])
  @@index([expiresAt])
}

/// Demande envoyee a un intervenant. Version moderne et complete de
/// IntervenantRequest (laisse en place pour retrocompat). Supporte tous
/// les types de workflow (pose, livraison, SAV, mesure, devis, confirmation
/// commande...) avec un fil de messages, des PJ, et un audit log de statut.
model Demande {
  id              String         @id @default(cuid())
  workspaceId     String
  /// L'intervenant cible. Null si la demande est en cours de redaction
  /// avant assignation finale (cas tres rare, pour brouillons).
  intervenantId   String?
  /// Optionnel : projet/dossier auquel la demande est rattachee.
  projectId       String?
  /// Optionnel : event planning declencheur (cas planning -> demande auto).
  eventId         String?
  type            DemandeType    @default(AUTRE)
  status          DemandeStatus  @default(ENVOYEE)
  title           String
  /// Note libre du pro (le brief de la demande).
  notes           String?        @db.Text
  /// Date prevue (deadline souhaitee) — informative, pas bloquante.
  scheduledFor    DateTime?
  /// Reponse libre de l'intervenant a l'acceptation/refus.
  responseMessage String?        @db.Text
  /// Premiere ouverture de la demande par l'intervenant (vue).
  viewedAt        DateTime?
  acceptedAt      DateTime?
  refusedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  /// Createur cote pro.
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  intervenant     Intervenant?       @relation(fields: [intervenantId], references: [id], onDelete: SetNull)
  project         Project?           @relation("DemandeProject", fields: [projectId], references: [id], onDelete: SetNull)
  event           Event?             @relation("DemandeEvent", fields: [eventId], references: [id], onDelete: SetNull)
  createdBy       User               @relation("DemandeCreatedBy", fields: [createdById], references: [id])
  messages        DemandeMessage[]
  attachments     DemandeAttachment[]
  statusEvents    DemandeStatusEvent[]

  @@index([workspaceId, status])
  @@index([intervenantId, status])
  @@index([projectId])
  @@index([eventId])
}

/// Message dans le fil de discussion d'une demande.
/// Auteur peut etre cote pro (User pro) ou cote intervenant (User intervenant).
model DemandeMessage {
  id            String   @id @default(cuid())
  demandeId     String
  /// Auteur — peut etre n'importe quel User (pro ou intervenant).
  authorId      String
  /// Cache du nom affiche (snapshot au moment de l'envoi).
  authorName    String
  /// 'pro' ou 'intervenant' selon le contexte de l'envoi.
  authorRole    String
  body          String   @db.Text
  createdAt     DateTime @default(now())

  demande       Demande  @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  author        User     @relation("DemandeMessageAuthor", fields: [authorId], references: [id])

  @@index([demandeId, createdAt])
}

/// Piece jointe attachee a une demande (lien vers DossierDocument
/// existant, ou Document admin si pertinent). Permet au pro de joindre
/// les plans / devis / photos a une demande sans dupliquer le fichier.
model DemandeAttachment {
  id            String   @id @default(cuid())
  demandeId     String
  /// L'un OU l'autre — jamais les deux.
  dossierDocumentId String?
  documentId        String?
  /// Snapshot du nom au moment de l'ajout (le doc peut etre supprime).
  displayName       String
  /// Cache pratique du mime pour affichage liste.
  mimeType          String?
  /// 'pro' ou 'intervenant' selon qui a uploade.
  uploadedByRole    String
  uploadedById      String
  createdAt         DateTime @default(now())

  demande           Demande         @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  dossierDocument   DossierDocument? @relation(fields: [dossierDocumentId], references: [id], onDelete: SetNull)
  document          Document?       @relation("DemandeAttachmentDoc", fields: [documentId], references: [id], onDelete: SetNull)
  uploadedBy        User            @relation("DemandeAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([demandeId])
  @@index([dossierDocumentId])
  @@index([documentId])
}

/// Audit log des changements de statut sur une demande.
/// Permet de reconstituer la timeline complete : qui a passe de ENVOYEE
/// a VUE, quand, etc. Conservation indefinie (donnees compactes).
model DemandeStatusEvent {
  id            String         @id @default(cuid())
  demandeId     String
  fromStatus    DemandeStatus?
  toStatus      DemandeStatus
  /// Auteur du changement (pro ou intervenant).
  triggeredById String
  triggeredByRole String
  /// Optionnel : commentaire associe au changement.
  comment       String?
  createdAt     DateTime       @default(now())

  demande       Demande @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  triggeredBy   User    @relation("DemandeStatusEventTriggeredBy", fields: [triggeredById], references: [id])

  @@index([demandeId, createdAt])
}

model IntervenantRequest {
  id              String                   @id @default(cuid())
  intervenantId   String
  projectId       String
  status          IntervenantRequestStatus @default(PENDING)
  message         String?
  sentAt          DateTime?
  createdAt       DateTime                 @default(now())

  intervenant     Intervenant              @relation(fields: [intervenantId], references: [id], onDelete: Cascade)
  responses       IntervenantResponse[]

  @@index([intervenantId])
  @@index([projectId])
}

model IntervenantResponse {
  id            String             @id @default(cuid())
  requestId     String
  responseData  Json
  createdAt     DateTime           @default(now())

  request       IntervenantRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// STOCK & COMMANDES
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  website     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockItems     StockItem[]
  orders         SupplierOrder[]

  @@index([workspaceId])
}

model StockItem {
  id              String          @id @default(cuid())
  workspaceId     String
  supplierId      String?
  status          StockItemStatus @default(AVAILABLE)
  category        StockCategory   @default(AUTRE)
  sku             String?
  name            String
  model           String?
  color           String?
  material        String?
  purchasePrice   Decimal?        @db.Decimal(12, 2)
  salePrice       Decimal?        @db.Decimal(12, 2)
  quantity        Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supplier          Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  projectStockItems ProjectStockItem[]

  @@index([workspaceId])
}

model ProjectStockItem {
  projectId   String
  stockItemId String
  quantity    Int     @default(1)
  reserved    Boolean @default(false)

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@id([projectId, stockItemId])
}

model SupplierOrder {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  supplierId  String?
  reference   String?
  notes       String?
  orderedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  supplier    Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines       SupplierOrderLine[]

  @@index([workspaceId])
}

model SupplierOrderLine {
  id          String        @id @default(cuid())
  orderId     String
  sku         String?
  description String
  quantity    Int
  unitPrice   Decimal       @db.Decimal(12, 2)

  order       SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// DEVIS / QUOTES
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  version     Int      @default(1)
  status      String   @default("DRAFT")
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines       QuoteLine[]

  @@index([workspaceId])
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(20) @db.Decimal(5, 2)
  position    Int     @default(0)

  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PAIEMENT & SIGNATURE
// ─────────────────────────────────────────────────────────────────────────────

model PaymentRequest {
  id              String        @id @default(cuid())
  workspaceId     String
  projectId       String
  type            PaymentType   @default(ACOMPTE)
  amount          Decimal       @db.Decimal(12, 2)
  provider        String        @default("stripe")
  providerRef     String?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

model SignatureRequest {
  id          String          @id @default(cuid())
  workspaceId String
  projectId   String
  provider    String          @default("yousign")
  providerRef String?
  status      SignatureStatus @default(PENDING)
  signingUrl  String?
  signedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // YouSign specific fields
  documentTitle   String?
  signerEmail     String?
  signerName      String?
  signerPhone     String?
  message         String?
  yousignDocId    String?
  yousignSignerId String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// IA
// ─────────────────────────────────────────────────────────────────────────────

model IaJob {
  id               String      @id @default(cuid())
  workspaceId      String
  createdById      String
  projectId        String?
  type             IaJobType
  status           IaJobStatus @default(QUEUED)
  prompt           String?
  sourceDocumentId String?
  resultDocumentId String?
  errorMessage     String?
  completedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User       @relation(fields: [createdById], references: [id])
  project          Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceDocument   Document?  @relation("IaSourceDoc", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  resultDocument   Document?  @relation("IaResultDoc", fields: [resultDocumentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id          String            @id @default(cuid())
  workspaceId String
  userId      String
  scope       NotificationScope @default(SYSTEM)
  type        String
  message     String
  isRead      Boolean           @default(false)
  readAt      DateTime?
  createdAt   DateTime          @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // OPTIMISATION: Index pour les requêtes de notifications non lues par utilisateur
  @@index([workspaceId, userId, isRead])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String
  projectId   String?
  action      AuditAction
  changes     Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // OPTIMISATION: Index pour les requêtes audit courantes
  @@index([workspaceId])
  @@index([workspaceId, projectId])
  @@index([createdAt])
  @@index([userId])
}

model AutomationRule {
  id          String   @id @default(cuid())
  workspaceId String
  triggerKey  String
  configJson  Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WAITLIST (Bêta privée — lancement juillet 2026)
// ─────────────────────────────────────────────────────────────────────────────

model Waitlist {
  id         String   @id @default(cuid())
  email      String   @unique
  firstName  String?
  lastName   String?
  company    String?
  metier     String?  // architecte | cuisiniste | menuisier | agenceur | autre
  message    String?
  source     String?  // utm_source / referrer / page
  ipAddress  String?
  userAgent  String?
  notified   Boolean  @default(false) // email de confirmation envoyé
  invitedAt  DateTime? // si on invite à rejoindre la bêta
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([metier])
}

model DemoRequest {
  id         String   @id @default(cuid())
  email      String
  firstName  String?
  lastName   String?
  company    String?
  phone      String?
  metier     String?
  message    String?
  source     String?
  ipAddress  String?
  userAgent  String?
  contacted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}
