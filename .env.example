# ══════════════════════════════════════════════════════════════════════════════
# AVRA — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs réelles.
# ⚠️  Ne JAMAIS commiter .env sur Git — seul .env.example est versionné.
#
# Générer JWT_SECRET et JWT_REFRESH_SECRET avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Base de données (Supabase) ────────────────────────────────────────────────
# URL avec pgbouncer (pour les requêtes normales - évite le dépassement de connexions)
DATABASE_URL="postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# URL directe (pour les migrations Prisma)
DIRECT_URL="postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── JWT (OBLIGATOIRES — l'API refuse de démarrer si absents) ─────────────────
JWT_SECRET=REMPLACER_PAR_64_CARACTERES_ALEATOIRES
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REMPLACER_PAR_64_AUTRES_CARACTERES_ALEATOIRES
JWT_REFRESH_EXPIRES_IN=30d

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3002
# Origins autorisées pour CORS (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:3002

# ── Code bêta (optionnel — pour accès restreint en dev) ──────────────────────
# NEXT_PUBLIC_BETA_CODE=AVRA2026

# ── Compte démo (pour le bouton "Accès démo") ────────────────────────────────
# NEXT_PUBLIC_DEMO_EMAIL=demo@avra.fr
# NEXT_PUBLIC_DEMO_PASS=demo123

# ── Stockage fichiers ─────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── S3 (optionnel — pour le stockage fichiers en production) ─────────────────
S3_BUCKET=avra
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Stripe (optionnel — pour les paiements en ligne) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── IA — Claude / Anthropic (REQUIS pour le chat IA) ─────────────────────────
# Créer une clé sur: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-6

# ── IA — fal.ai (génération d'images 3D — optionnel) ─────────────────────────
# Créer une clé sur: https://fal.ai/dashboard/keys
FAL_KEY=

# ── IA — Qwen (désactivé — restrictions France) ──────────────────────────────
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── IA — Legacy (désactivé) ──────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Signature électronique (optionnel) ────────────────────────────────────────
YOUSIGN_API_KEY=
YOUSIGN_BASE_URL=https://api.yousign.app/v3

# ── Monitoring Sentry (optionnel) ─────────────────────────────────────────────
SENTRY_DSN=

# ── Bêta privée (lancement juillet 2026) ──────────────────────────────────────
# BETA_GATE_ENABLED=true    → bloque login/register sauf pour les emails whitelistés
# BETA_ADMIN_EMAILS=toi@email.fr,cofondatrice@email.fr
BETA_GATE_ENABLED=true
BETA_ADMIN_EMAILS=
