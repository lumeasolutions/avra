# ──────────────────────────────────────────────────────────────
#  AVRA — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
#  JAMAIS committer .env.local dans git
# ──────────────────────────────────────────────────────────────

# ── IA Studio — Flux via fal.ai ────────────────────────────────
# Obtenir la clé sur https://fal.ai/dashboard/keys
# Utilisée UNIQUEMENT côté serveur (API routes /api/ia/*)
# Ne jamais exposer cette clé côté client
FAL_KEY=fal-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── (Optionnel Phase 2) OpenAI — LLM pour prompt builder avancé
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Accès beta ──────────────────────────────────────────────────
# Code d'accès à la version bêta. Changer pour chaque déploiement.
# Ne jamais utiliser la valeur par défaut en production.
NEXT_PUBLIC_BETA_CODE=VOTRE_CODE_BETA_ICI

# ── Mode démo ───────────────────────────────────────────────────
# Identifiants du compte démo (email/mot de passe)
# Utiliser un compte à privilèges limités en production
NEXT_PUBLIC_DEMO_EMAIL=demo@avra.fr
NEXT_PUBLIC_DEMO_PASS=demo123

# ── Backend / API ────────────────────────────────────────────────
# URL du backend NestJS — DOIT être en HTTPS en production
NEXT_PUBLIC_API_URL=https://api.votre-domaine.com/api

# ── Rate limiting ────────────────────────────────────────────────
# Mettre à true UNIQUEMENT si un reverse proxy (nginx, Cloudflare, etc.)
# est configuré en frontal et transmet les vraies IPs clients.
# false par défaut pour éviter le spoofing IP sur les routes API.
TRUSTED_PROXY=false
