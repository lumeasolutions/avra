{
  "name": "avra-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm db:generate && pnpm --filter @avra/api dev & pnpm --filter @avra/web dev",
    "dev:web": "pnpm --filter @avra/web dev",
    "dev:api": "pnpm db:generate && pnpm --filter @avra/api dev",
    "db:generate": "node generate-prisma.js",
    "build": "pnpm db:generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "setup": "pnpm install && node generate-prisma.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0"
  }
}
